@model MedCareCore.Models.Doctor

@{
    ViewData["Title"] = "Edit Doctor Details";
}

<form method="post">
    <input asp-for="Id" hidden />

    <div class="border p-4 mt-4 card shadow-sm">
        <div class="row pb-2">
            <h2 class="text-primary">Edit Doctor Information</h2>
            <hr />
        </div>

        <div class="mb-3">
            <label asp-for="Name" class="form-label font-weight-bold"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Specialization" class="form-label font-weight-bold"></label>
            <input asp-for="Specialization" class="form-control" />
            <span asp-validation-for="Specialization" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ConsultationFee" class="form-label font-weight-bold"></label>
            <input asp-for="ConsultationFee" class="form-control" type="number" step="0.01" />
            <span asp-validation-for="ConsultationFee" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Phone" class="form-label font-weight-bold"></label>
            <input asp-for="Phone" class="form-control" />
            <span asp-validation-for="Phone" class="text-danger"></span>
        </div>

        <div class="mb-3 form-check form-switch">
            <input asp-for="IsAvailable" class="form-check-input" type="checkbox" />
            <label asp-for="IsAvailable" class="form-check-label">Available for appointments</label>
        </div>

        <div class="row pt-2">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-primary form-control">Update</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-controller="Doctors" asp-action="Index" class="btn btn-outline-secondary form-control">
                    Cancel
                </a>
            </div>
        </div>
    </div>
</form>

@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}