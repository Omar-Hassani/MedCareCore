@model MedCareCore.Models.MedicalRecord

@{
    ViewData["Title"] = "Consultation Details";
}

<div class="container p-3">
    <div class="card shadow border-0 mt-4">
        <div class="card-header bg-info bg-gradient text-white p-3 d-flex justify-content-between align-items-center">
            <h3 class="mb-0"><i class="bi bi-file-earmark-medical"></i> Medical Prescription Sheet</h3>
            <span class="badge bg-light text-dark shadow-sm">Generated: @Model.CreatedAt.ToString("g")</span>
        </div>
        <div class="card-body p-4 bg-light">
            <div class="row mb-4">
                <div class="col-md-6 mb-3 mb-md-0">
                    <div class="p-3 bg-white border rounded shadow-sm h-100">
                        <small class="text-muted d-block uppercase fw-bold small"><i class="bi bi-person-fill"></i> Patient Details</small>
                        <h4 class="text-primary mb-1">@Model.Appointment?.Patient?.Name</h4>
                        <p class="mb-0 text-muted">Phone: @Model.Appointment?.Patient?.Phone</p>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="p-3 bg-white border rounded shadow-sm h-100">
                        <small class="text-muted d-block uppercase fw-bold small"><i class="bi bi-heart-pulse-fill"></i> Attending Provider</small>
                        <h4 class="text-success mb-1">Dr. @Model.Appointment?.Doctor?.Name</h4>
                        <p class="mb-0 text-muted">Specialization: @Model.Appointment?.Doctor?.Specialization</p>
                    </div>
                </div>
            </div>

            <div class="mb-4 p-3 bg-white border rounded shadow-sm">
                <h5 class="text-danger border-bottom pb-2 fw-bold"><i class="bi bi-activity"></i> Clinical Diagnosis & Observations</h5>
                <p class="text-dark bg-light p-3 border rounded style-plain mb-0" style="white-space: pre-line;">@Model.Diagnosis</p>
            </div>

            <div class="mb-4 p-3 bg-white border rounded shadow-sm">
                <h5 class="text-success border-bottom pb-2 fw-bold"><i class="bi bi-capsule-hd"></i> Ordered Treatment / Prescription (Rx)</h5>
                <div class="text-dark bg-light p-3 border rounded font-monospace fs-5" style="white-space: pre-line; background-color: #fafbfc !important;">
                    @Model.Prescription
                </div>
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    <div class="p-3 bg-white border rounded shadow-sm h-100">
                        <span class="fw-bold d-block mb-1"><i class="bi bi-paperclip"></i> Lab / Imaging Attachments</span>
                        <span class="text-muted">@(string.IsNullOrEmpty(Model.AttachmentFilePath) ? "No files submitted" : Model.AttachmentFilePath)</span>
                    </div>
                </div>
                <div class="col-md-6 mb-3">
                    <div class="p-3 bg-white border rounded shadow-sm h-100">
                        <span class="fw-bold d-block mb-1"><i class="bi bi-arrow-repeat"></i> Follow-up Orders</span>
                        <span class="text-muted">@(string.IsNullOrEmpty(Model.FollowUpNotes) ? "No recall requested" : Model.FollowUpNotes)</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer bg-white p-3 d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Back to History</a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4"><i class="bi bi-pencil-square"></i> Edit Entry</a>
        </div>
    </div>
</div>