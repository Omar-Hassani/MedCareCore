@model MedCareCore.Models.MedicalRecord

@{
    Layout = null; // إزالة الـ Layout العام للموقع لكي لا يظهر شريط التنقل أو القوائم الجانبية
    ViewData["Title"] = "Print Prescription";
}

<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MedCare - الروشتة الطبية</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .prescription-paper {
            background: #fff;
            border-top: 6px solid #0d6efd;
            box-shadow: 0 0 15px rgba(0,0,0,0.05);
            min-height: 297mm; /* طول ورقة A4 */
            padding: 20mm 15mm;
            position: relative;
        }

        .clinic-logo-section {
            border-bottom: 2px solid #dee2e6;
            padding-bottom: 20px;
        }

        .info-badge {
            background-color: #f1f3f5;
            border-right: 4px solid #0d6efd;
            padding: 10px 15px;
            border-radius: 0 4px 4px 0;
        }

        .section-title {
            color: #0d6efd;
            font-weight: bold;
            border-bottom: 2px solid #e9ecef;
            padding-bottom: 5px;
            margin-top: 30px;
            margin-bottom: 15px;
        }

        .rx-symbol {
            font-size: 2.5rem;
            font-weight: 800;
            color: #0d6efd;
            font-style: italic;
            font-family: 'Times New Roman', Times, serif;
        }

        .content-area {
            font-size: 1.1rem;
            line-height: 1.6;
            white-space: pre-line; /* الحفاظ على أسطر النص المرسلة من الداتا بيز كما هي */
        }

        /* 🖨️ هندسة كود الطباعة الذكي باستخدام الـ Escape */
        @@media print {
            body {
                background-color: #fff;
            }

            .prescription-paper {
                box-shadow: none !important;
                padding: 0 !important;
                border-top: none !important;
            }

            .no-print {
                display: none !important; /* إخفاء الأزرار أثناء الطباعة */
            }
        }
    </style>
</head>
<body>

    <div class="container my-5 no-print text-center">
        <button onclick="window.print();" class="btn btn-success btn-lg me-2 shadow-sm">
            <i class="bi bi-printer-fill"></i> طباعة فورية أو حفظ كـ PDF
        </button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-lg shadow-sm">
            <i class="bi bi-arrow-left-short"></i> العودة للسجلات الطبية
        </a>
    </div>

    <div class="container">
        <div class="prescription-paper mx-auto col-lg-9">

            <div class="row clinic-logo-section align-items-center">
                <div class="col-6">
                    <h2 class="text-primary fw-bold mb-1"><i class="bi bi-heart-pulse-fill"></i> MedCare</h2>
                    <p class="text-muted small mb-0">مركز الرعاية الطبية الرقمي والخدمات العلاجية المتكاملة</p>
                </div>
                <div class="col-6 text-start">
                    <h5 class="fw-bold text-dark">دكتور: @Model.Appointment?.Doctor?.Name</h5>
                    <p class="text-muted small mb-0">تاريخ الكشف: @Model.Appointment?.AppointmentDate.ToString("dd/MM/yyyy - hh:mm tt")</p>
                </div>
            </div>

            <div class="row mt-4 mb-2">
                <div class="col-md-7 mb-2">
                    <div class="info-badge">
                        <span class="text-muted small d-block">اسم المريض</span>
                        <strong class="text-dark fs-5">@Model.Appointment?.Patient?.Name</strong>
                    </div>
                </div>
                <div class="col-md-5 mb-2">
                    <div class="info-badge">
                        <span class="text-muted small d-block">رقم السجل الطبي الموحد</span>
                        <strong class="text-dark">#REC-@Model.Id</strong>
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12">
                    <h5 class="section-title"><i class="bi bi-clipboard2-pulse"></i> التشخيص الطبي (Diagnosis)</h5>
                    <div class="content-area p-3 bg-light rounded text-dark">
                        @Model.Diagnosis
                    </div>
                </div>
            </div>

            <div class="row mt-4">
                <div class="col-12">
                    <h5 class="section-title d-flex align-items-center justify-content-between">
                        <span><i class="bi bi-capsule"></i> الوصفة العلاجية (Prescription)</span>
                        <span class="rx-symbol">℞</span>
                    </h5>
                    <div class="content-area p-3 border border-dashed border-2 rounded text-dark bg-white" style="min-height: 180px;">
                        @Model.Prescription
                    </div>
                </div>
            </div>

            <div class="position-absolute bottom-0 start-0 end-0 px-5 pb-5" style="margin-bottom: 20px;">
                <div class="row border-top pt-3 align-items-center">
                    <div class="col-6 text-muted small">
                        * صالحة للاستخدام لمرة واحدة مالم يذكر الطبيب غير ذلك.
                    </div>
                    <div class="col-6 text-start">
                        <p class="mb-0 fw-bold text-secondary">توقيع وختم الطبيب المعالج</p>
                        <p class="text-muted small">________________________</p>
                    </div>
                </div>
            </div>

        </div>
    </div>

</body>
</html>