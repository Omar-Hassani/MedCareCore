@model MedCareCore.Models.MedicalRecord

@{
    ViewData["Title"] = "New Medical Record";
}

<div class="container p-3">
    <form method="post" enctype="multipart/form-data">
        <div class="border p-4 mt-4 card shadow-sm border-0">
            <div class="border-bottom pb-2 mb-4">
                <h2 class="text-primary"><i class="bi bi-pencil-square"></i> Clinical Examination Sheet</h2>
                <p class="text-muted mb-0">Select an active patient appointment to log medical findings and treatments.</p>
            </div>

            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-4">
                <label class="form-label fw-bold">Select Active Appointment</label>
                <select asp-for="AppointmentId" asp-items="@(ViewBag.AppointmentList as IEnumerable<SelectListItem>)" class="form-select border-primary">
                    <option disabled selected>-- Select Patient & Appointment Slot --</option>
                </select>
                <span asp-validation-for="AppointmentId" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Diagnosis" class="form-label fw-bold"></label>
                <textarea asp-for="Diagnosis" class="form-control" rows="3" placeholder="Enter full details of symptoms, clinical signs, and physical findings..."></textarea>
                <span asp-validation-for="Diagnosis" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Prescription" class="form-label fw-bold"></label>
                <textarea asp-for="Prescription" class="form-control font-monospace" rows="4" placeholder="Rx:&#10;1. Drug Name - Dosage - Frequency - Duration.&#10;2. ..."></textarea>
                <span asp-validation-for="Prescription" class="text-danger"></span>
            </div>

            <div class="row mb-3">
                <div class="col-md-12">
                    <label class="form-label fw-bold text-secondary">
                        <i class="bi bi-file-earmark-arrow-up-fill text-primary"></i> رفع المرفقات الطبية (صور أشعة، تحاليل PDF)
                    </label>

                    <input type="file" name="uploadedFile" class="form-control shadow-sm border-primary-subtle" accept=".pdf,.jpg,.jpeg,.png" />

                    <div class="form-text text-muted small mt-1">
                        * الصيغ المسموح بها: PDF, JPG, PNG. يتم تشفير اسم الملف وتخزينه بشكل آمن على السيرفر.
                    </div>
                </div>
            </div>

            <div class="row mb-4">
                <div class="col-md-6">
                    <label asp-for="FollowUpNotes" class="form-label fw-bold"></label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                        <input asp-for="FollowUpNotes" class="form-control" placeholder="e.g., Re-check after 10 days" />
                    </div>
                    <span asp-validation-for="FollowUpNotes" class="text-danger"></span>
                </div>
            </div>

            <div class="row pt-3 border-top mt-4">
                <div class="col-6 col-md-3">
                    <button type="submit" class="btn btn-primary form-control shadow-sm">
                        <i class="bi bi-check-circle"></i> Save Consultation
                    </button>
                </div>
                <div class="col-6 col-md-3">
                    <a asp-action="Index" class="btn btn-outline-secondary form-control">Cancel</a>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}