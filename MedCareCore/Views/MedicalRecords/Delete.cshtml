@model MedCareCore.Models.MedicalRecord

@{
    ViewData["Title"] = "Delete Consultation Record";
}

<div class="container p-3">
    <form method="post" asp-action="Delete">
        <input asp-for="Id" hidden />

        <div class="border p-4 mt-4 card shadow-sm border-danger border-2">
            <div class="border-bottom pb-2 mb-4">
                <h2 class="text-danger"><i class="bi bi-exclamation-triangle-fill"></i> Void Medical Record?</h2>
                <p class="text-muted mb-0">Critical Action: You are about to wipe this medical entry. This will result in permanent loss of diagnostic data.</p>
            </div>

            <div class="row p-3 bg-light rounded border mb-4">
                <div class="col-md-4 mb-2">
                    <span class="text-muted d-block">Patient Name:</span>
                    <strong>@Model.Appointment?.Patient?.Name</strong>
                </div>
                <div class="col-md-4 mb-2">
                    <span class="text-muted d-block">Doctor Name:</span>
                    <strong>@Model.Appointment?.Doctor?.Name</strong>
                </div>
                <div class="col-md-4 mb-2">
                    <span class="text-muted d-block">Consultation Timestamp:</span>
                    <strong>@Model.CreatedAt.ToString("g")</strong>
                </div>
            </div>

            <div class="mb-3">
                <label class="fw-bold text-muted">Diagnosis Summary:</label>
                <p class="p-2 border bg-white rounded text-truncate">@Model.Diagnosis</p>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger px-4 shadow-sm">
                    <i class="bi bi-trash"></i> Permanently Delete Record
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel and Return</a>
            </div>
        </div>
    </form>
</div>