@model MedCareCore.Models.Appointment

<form method="post" asp-action="Delete">
    <input asp-for="Id" hidden />

    <div class="border p-4 mt-4 card shadow-sm border-danger">
        <h2 class="text-danger">Cancel & Delete Appointment?</h2>
        <p class="text-muted">Are you sure you want to completely remove this appointment record?</p>
        <hr />

        <div class="row mb-3">
            <div class="col-md-4">
                <strong>Patient Name:</strong>
                <input class="form-control mt-1" value="@Model.Patient.Name" disabled />
            </div>
            <div class="col-md-4">
                <strong>Doctor Name:</strong>
                <input class="form-control mt-1" value="@Model.Doctor.Name" disabled />
            </div>
            <div class="col-md-4">
                <strong>Scheduled Date:</strong>
                <input class="form-control mt-1" value="@Model.AppointmentDate.ToString("f")" disabled />
            </div>
        </div>

        <div class="row pt-2">
            <div class="col-6 col-md-3">
                <button type="submit" class="btn btn-danger form-control">Confirm Delete</button>
            </div>
            <div class="col-6 col-md-3">
                <a asp-action="Index" class="btn btn-outline-secondary form-control">Back to List</a>
            </div>
        </div>
    </div>
</form>