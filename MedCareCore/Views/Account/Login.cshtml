@model MedCareCore.Models.ViewModels.LoginVM

@{
    ViewData["Title"] = "Log in";
}

<div class="row justify-content-center pt-5">
    <div class="col-md-5">
        <div class="card shadow border-0 rounded p-4">
            <div class="text-center mb-4">
                <h2 class="text-primary fw-bold"><i class="bi bi-shield-lock"></i> MedCare Portal</h2>
                <p class="text-muted">Sign in to manage your clinic dashboard</p>
            </div>

            <form method="post">
                <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                    <label asp-for="Email"></label>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Password" class="form-control" placeholder="Password" />
                    <label asp-for="Password"></label>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="checkbox mb-3 d-flex justify-content-between">
                    <label asp-for="RememberMe" class="form-label">
                        <input class="form-check-input" asp-for="RememberMe" />
                        @Html.DisplayNameFor(m => m.RememberMe)
                    </label>
                </div>

                <button type="submit" class="w-100 btn btn-lg btn-primary shadow-sm">Log in</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}