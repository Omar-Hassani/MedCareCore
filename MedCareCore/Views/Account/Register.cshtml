@model MedCareCore.Models.ViewModels.RegisterVM

@{
    ViewData["Title"] = "Register Staff";
}

<div class="row justify-content-center pt-5">
    <div class="col-md-6">
        <div class="card shadow border-0 rounded p-4">
            <div class="border-bottom pb-2 mb-4">
                <h2 class="text-primary fw-bold"><i class="bi bi-person-plus-fill"></i> Register New Staff/Doctor</h2>
                <p class="text-muted mb-0">Create credentials and assign administrative roles.</p>
            </div>

            <form method="post">
                <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                    <label asp-for="Email"></label>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Password" class="form-control" placeholder="Password" />
                    <label asp-for="Password"></label>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm Password" />
                    <label asp-for="ConfirmPassword"></label>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Select User Role</label>
                    <select asp-for="SelectedRole" asp-items="@Model.RoleList" class="form-select border-primary py-2">
                        <option disabled selected>-- Assign System Role --</option>
                    </select>
                    <span asp-validation-for="SelectedRole" class="text-danger small"></span>
                </div>

                <button type="submit" class="w-100 btn btn-lg btn-success shadow-sm">Register User</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}